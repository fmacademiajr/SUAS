# ─── App ─────────────────────────────────────────────────────────────────────
APP_ENV=local                           # local | staging | production
LOG_LEVEL=INFO

# Only this Google account can access the dashboard
ALLOWED_USER_EMAIL=your-email@gmail.com

# ─── GCP ─────────────────────────────────────────────────────────────────────
GCP_PROJECT_ID=suas-local               # Your GCP project ID
GCS_BUCKET_NAME=suas-local-images       # Cloud Storage bucket for generated images

# Set this for local dev to use the Firestore emulator (leave empty in production)
FIRESTORE_EMULATOR_HOST=localhost:8080

# ─── Anthropic ───────────────────────────────────────────────────────────────
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ─── Google AI (Gemini) ───────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# ─── Facebook ────────────────────────────────────────────────────────────────
# Your Facebook Page ID (visible in Page settings)
FACEBOOK_PAGE_ID=your-page-id

# Long-lived Page Access Token (60-day expiry) — generate from Meta Developer Portal
# https://developers.facebook.com/tools/explorer/
FACEBOOK_PAGE_ACCESS_TOKEN=EAAx...

# ─── Reddit ──────────────────────────────────────────────────────────────────
# Register at: https://www.reddit.com/prefs/apps (script type)
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=SUAS/1.0

# ─── Scheduler ───────────────────────────────────────────────────────────────
TIMEZONE=Asia/Manila

# ─── Model IDs (override if you want to pin to a specific version) ───────────
MODEL_HAIKU=claude-haiku-4-5-20251001
MODEL_SONNET=claude-sonnet-4-6
MODEL_OPUS=claude-opus-4-6
