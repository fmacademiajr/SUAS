# Firebase project config (safe to expose — security is via Firebase rules + backend auth gate)
# Get these from your Firebase project settings
VITE_FIREBASE_API_KEY=AIza...
VITE_FIREBASE_AUTH_DOMAIN=suas-xxxxx.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=suas-xxxxx
VITE_FIREBASE_STORAGE_BUCKET=suas-xxxxx.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# Backend API URL (leave empty to use Vite proxy in dev)
VITE_API_URL=
